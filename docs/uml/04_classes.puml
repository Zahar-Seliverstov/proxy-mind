@startuml ProxyMind_Classes
title ProxyMind — Диаграмма классов\n(основные структуры данных)

skinparam defaultFontName Arial
skinparam classAttributeIconSize 0

note as N1
  Персистентные данные хранятся в SQLite
  (~/.config/proxymind/proxymind.db) через
  SQLAlchemy 2.0 async ORM (aiosqlite).
  Оперативное состояние запусков — in-memory (_runs dict).
end note

class "_Run" as Run {
  + pane_id: str
  + model: str
  + prompts: list[str]
  + status: RunStatus
  + step_index: int
  + sent_current_step: bool
  + last_decision: Decision | None
  + log: list[DecisionLogEntry]
  + error: str | None
  + task: asyncio.Task | None
  --
  + snapshot() : dict
}

enum "RunStatus" as Status {
  running
  user_paused
  done
  error
  stopped
}

class "DecisionLogEntry" as LogEntry {
  + at: float
  + step_index: int
  + state: AnalyzerState
  + reason: str
  + payload: dict
}

enum "AnalyzerState" as AState {
  working
  next_step
  done
  error
  ask_user
}

class "Decision" as Dec {
  + state: AnalyzerState
  + reason: str
  + payload: AskPayload | {}
}

class "AskPayload" as AskP {
  + question: str
  + kind: AskKind
  + options: list[Option]
}

enum "AskKind" as Kind {
  yesno
  choice
  open
}

class "Option" as Opt {
  + label: str
  + value: str
}

' ── ORM-модели (SQLAlchemy, таблицы SQLite) ──────────────────────────────

class "Prompt" as DBPrompt {
  + id: int <<PK>>
  + name: str
  + content: str
  + format_hint: str | None
}

class "Mode" as DBMode {
  + key: str <<PK>>
  + label: str
  + description: str
  + prompt_id: int | None <<FK>>
}

class "Setting" as DBSetting {
  + key: str <<PK>>
  + value: str | None
}

DBMode "0..*" --> "0..1" DBPrompt : prompt_id

' ── Конфигурация в памяти ────────────────────────────────────────────────

class "Settings" as Cfg {
  + ollama_base_url: str
  + telegram_bot_token: str
  + telegram_chat_id: str
  --
  Источник: таблица settings в SQLite
}

class "ValidationResult" as ValR {
  + status: "ok" | "low_info" | "off_topic" | "gibberish"
}

class "Question" as Q {
  + text: str
  + options: list[str]
}

Run "1" *-- "0..*" LogEntry : log
Run --> Status : status
LogEntry --> AState : state
Dec --> AState : state
Dec "1" *-- "0..1" AskP : payload
AskP --> Kind : kind
AskP "1" *-- "0..*" Opt : options
@enduml
